{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.roadmaptic.qzz.io"
        }
      ],
      "destination": "https://roadmaptic.qzz.io/$1",
      "statusCode": 301
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|sitemap\\.xml|robots\\.txt|_redirects|favicon\\.svg|icons\\.svg|assets/).*)",
      "destination": "/index.html"
    }
  ]
}
